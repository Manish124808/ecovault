# ─────────────────────────────────────────────
# EcoVault Server — Environment Variables
# Copy this to .env and fill in real values
# ─────────────────────────────────────────────

# MongoDB
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/ecovault

# Firebase Admin (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=e-waste-3b8cf
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@e-waste-3b8cf.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# EmailJS (Render blocks SMTP — use EmailJS HTTP API instead)
# Get values from: https://dashboard.emailjs.com
# IMPORTANT: These must exactly match your EmailJS dashboard values
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_PRIVATE_KEY=your_private_key_here   # Account → API Keys → Private Key

# Gemini AI
# Get from: https://aistudio.google.com/app/apikey
# Key must start with "AIza" — multiple keys supported (comma-separated)
# Free tier: 15 RPM, 1M TPM, 1500 RPD on gemini-2.0-flash
# Test your key at: https://your-render-url.onrender.com/api/ai/ping-gemini
GEMINI_API_KEY=AIzaSy...your_real_key_here

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Admin email (used for withdrawal notifications & admin check)
ADMIN_EMAIL=youradmin@gmail.com

# App
PORT=5000
CLIENT_URL=https://your-frontend.onrender.com
